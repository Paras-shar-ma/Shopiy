<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link rel="stylesheet" href="../stylesheet/home.css">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="/javaScript/cartAmount.js" defer></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/js/all.min.js"
    integrity="sha512-6BTOlkauINO65nLhXhthZMtepgJSghyimIalb+crKRPhvhmsCdnIuGcVbR5/aQY2A+260iC1OPy1oCdB6pSSwQ=="
    crossorigin="anonymous" referrerpolicy="no-referrer"></script>
</head>

<body>
  <%- include('partials/header') %>

    <div class="main min-h-screen bg-gradient-to-br from-zinc-900 via-zinc-800 to-zinc-900 px-4 sm:px-6 py-6 sm:py-10 text-white">

      <!-- Header -->
      <div class="text-center mb-10 relative">
        <% if(typeof queryMessage !== 'undefined' && queryMessage){%>
          <div class="toast absolute -top-4 w-full flex justify-center items-center z-50">
              <div class="px-4 py-3 <%= typeof queryType !== 'undefined' && queryType === 'success' ? 'bg-green-500' : 'bg-red-500' %> rounded-lg text-white font-semibold shadow-lg">
                  <%= queryMessage %>
              </div>
          </div>
        <%}%>
        <h2 class="text-3xl font-bold tracking-wide mt-8">Your Cart</h2>
        <p class="text-zinc-400 mt-1">Items you’ve added to your cart</p>
      </div>

      <!-- Layout -->
      <div class="max-w-7xl mx-auto flex flex-col lg:flex-row gap-10">

        <!-- Left: Items -->
        <div class="flex-1 space-y-8">

          <!-- Item 1 -->
          <%products.cart.forEach((product)=>{%>
            <div class="cart flex flex-col sm:flex-row items-center border-b border-zinc-700 pb-5 gap-4 sm:gap-0 text-center sm:text-left">
              <!-- Image -->
              <img src="<%=product.image 
              ? `data:image/jpeg;base64,${product.image.toString('base64')}` 
              : '/images/default.png' %>" alt="Product Image"
                class="h-32 w-32 object-cover rounded-lg border border-zinc-700">

              <!-- Info -->
              <div class="sm:ml-5 flex-1 w-full">
                <h3 class="text-xl font-semibold">
                  <%=product.name%>
                </h3>
                <p class="text-zinc-400 text-sm mt-1">
                  <%=product.description%>
                </p>

                <div class="cart-box mt-2 flex items-center justify-between">
                  <span class="item-total text-blue-400 font-semibold text-lg">₹<%=product.price%></span>
                  <span class="item-discount hidden text-blue-400 font-semibold text-lg"
                    data-price="<%= product.discount%>"></span>

                  <div class="flex items-center space-x-3">
                    <input type="number" value="1" min="1"
                      class="quantity w-14 bg-zinc-700 text-center rounded-md text-white outline-none"
                      data-price="<%= product.price%>">
                    <a href="/user/removetocart/<%=product._id%>" title="remove item"
                      class="text-red-500 hover:text-red-400 text-sm font-semibold"><i
                        class="fa-solid fa-trash-can"></i></a>
                  </div>
                </div>
              </div>
            </div>
            <%})%>

        </div>

        <!-- Right: Order Summary -->
        <div class="lg:w-1/3 bg-zinc-800 border border-zinc-700 rounded-2xl shadow-xl p-6 h-fit sticky top-10">
          <h3 class="text-2xl font-bold mb-5 border-b border-zinc-700 pb-3">Order Summary</h3>

          <div class="space-y-3 text-zinc-300">
            <!-- <div class="total-price flex justify-between"><span>Subtotal</span><span>₹3998</span></div>
        <div class="flex justify-between"><span>Discount</span><span>-₹200</span></div>
        <div class="flex justify-between text-white font-semibold border-t border-zinc-700 pt-3">
          <span>Total</span><span>₹3798</span>
        </div> -->
            <div class="flex justify-between"><span>Subtotal</span>
              <span class="subtotal">₹0</span>
            </div>
            <div class="flex justify-between"><span>Discount</span><span class="discount">₹0</span></div>
            <div class="flex justify-between text-white font-semibold border-t border-zinc-700 pt-3">
              <span>Total</span>
              <span class="total">₹0</span>
            </div>
          </div>

          <a href="/user/checkout" class="block">
            <button
              class="mt-6 w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg transition duration-300">
              Proceed to Checkout
            </button>
          </a>
        </div>

      </div>
    </div>

</body>

</html>