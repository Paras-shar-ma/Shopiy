<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Home</title>
  <link rel="stylesheet" href="../stylesheet/home.css">
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js" crossorigin="anonymous" referrerpolicy="no-referrer"></script>
  <script src="../javaScript/flashMessages.js"></script>
</head>

<body>
  <%- include('partials/header') %>

    <div class="home w-full min-h-screen bg-gradient-to-br from-zinc-900 to-blue-900 text-white px-4 sm:px-10">

      <% if(typeof queryMessage !=='undefined' && queryMessage){%>
        <div class="toast h-full w-full flex justify-center items-center  ">
          <div class="w-auto px-4 py-3 bg-blue-500  rounded-lg text-white">
            <%= queryMessage %>
          </div>
        </div>
        <%}%>
          <!-- Page Title -->
          <div class="text-center mb-12 py-16">
            <h2 class="text-4xl font-bold tracking-wide">Our Products</h2>
            <p class="text-zinc-400 mt-2 text-sm">Browse through our latest items</p>
          </div>

          <!-- Products Section -->
          <div class="products w-full flex flex-wrap justify-center gap-10">

            <!-- Single Product -->
            <%products.reverse().forEach((product)=>{%>
              <div
                class="product bg-zinc-800/70 border border-zinc-700 rounded-xl w-64 h-80 shadow-lg hover:shadow-blue-500/20 transition-all duration-300 relative">

                <div class="image h-48 w-full rounded-t-xl overflow-hidden relative">
                  <!-- Owner Toggle Option - Top Right -->
                  <% if(typeof isOwner !='undefined' && isOwner){%>
                    <a href="/products/outofstock/<%= product._id%>"
                      class="absolute top-2 right-2 z-20 p-2 bg-zinc-900/80 hover:bg-zinc-800 rounded-full transition-colors group/toggle"
                      title="<%= product.isOutOfStock ? 'Mark In Stock' : 'Mark Out of Stock' %>">
                      <div
                        class="w-3 h-3 rounded-full <%= product.isOutOfStock ? 'bg-green-500' : 'bg-red-500' %> shadow-[0_0_8px_rgba(239,68,68,0.5)]">
                      </div>
                    </a>
                    <% } %>

                      <img src="<%=product.image 
              ? `data:image/jpeg;base64,${product.image.toString('base64')}` 
              : '../images/default.png' %>" alt="Product Image"
                        class="h-full w-full object-cover hover:scale-105 transition duration-500 <%= product.isOutOfStock ? 'blur-sm grayscale opacity-60' : '' %>">

                      <% if(product.isOutOfStock) { %>
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                          <div
                            class="bg-red-600/90 text-white font-black text-lg py-1 px-8 rotate-[-25deg] shadow-2xl border-y-2 border-white uppercase tracking-tighter whitespace-nowrap">
                            Out of Stock
                          </div>
                        </div>
                        <% } %>
                </div>

                <div class="content mt-4 px-4 ">
                  <h3 class="name text-xl font-semibold text-white">
                    <%=product.name%>
                  </h3>
                  <h4 class="price text-zinc-400 mt-1">₹<%=product.price%>
                  </h4>
                  <div class="flex items-center justify-between">
                    <a href="/products/product/<%=product._id%>"
                      class="inline-block mt-3 text-blue-400 font-medium hover:text-blue-300 transition duration-300">See
                      More →</a>
                    <% if(typeof isOwner !='undefined' && isOwner){%>
                      <a href="/products/delete/<%= product._id%>"
                        class="mt-3 text-xs text-red-400 font-medium hover:text-red-500 transition duration-300">Delete</a>
                      <% } %>
                  </div>
                </div>
              </div>
              <%})%>


          </div>
    </div>

</body>

</html>